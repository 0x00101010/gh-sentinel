{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "gh-sentinel",
  "title": "GitHub Sentinel",
  "description": "Unified GitHub triage — PRs, issues, and notifications in one menu bar item with priority scoring",
  "icon": "command-icon.png",
  "author": "francis",
  "categories": ["Developer Tools"],
  "license": "MIT",
  "commands": [
    {
      "name": "sentinel-menu-bar",
      "title": "Sentinel",
      "description": "Menu bar triage for GitHub notifications, PRs, and issues",
      "mode": "menu-bar",
      "interval": "1m"
    },
    {
      "name": "configure-watched-repos",
      "title": "Configure Watched Repos",
      "description": "Select repos to watch and configure notification preferences",
      "mode": "view"
    }
  ],
  "preferences": [
    {
      "name": "reviewCommand",
      "title": "Review CLI",
      "description": "CLI tool for LLM review",
      "type": "dropdown",
      "required": false,
      "default": "claude",
      "data": [
        { "title": "Claude", "value": "claude" },
        { "title": "OpenCode", "value": "opencode" }
      ]
    },
    {
      "name": "reviewPrompt",
      "title": "Review Prompt",
      "description": "Prompt template with {diff} placeholder",
      "type": "textfield",
      "required": false,
      "default": "Review this PR diff. Focus on bugs, security issues, and design problems. Be concise.\n\n{diff}"
    },
    {
      "name": "terminalNotifierPath",
      "title": "terminal-notifier Path",
      "description": "Path to terminal-notifier binary",
      "type": "textfield",
      "required": false,
      "default": "/opt/homebrew/bin/terminal-notifier"
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.93.0",
    "@raycast/utils": "^1.17.0"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^1.0.11",
    "@types/node": "22.x",
    "@types/react": "19.x",
    "eslint": "^8.57.0",
    "typescript": "^5.7.0"
  },
  "scripts": {
    "build": "ray build",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint",
    "prepublishOnly": "echo \"Error: no publish\" && exit 1",
    "publish": "npx @raycast/api@latest publish"
  }
}
